{
  "name": "@alwaysyou/templates",
  "version": "0.2.0",
  "description": "AlwaysYou template SDK — hooks, types, CLI tools, and local-dev tools for building gift templates.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "alwaysyou": "./scripts/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "default": "./dist/dev.js"
    },
    "./studio": {
      "types": "./dist/studio.d.ts",
      "default": "./dist/studio.js"
    }
  },
  "files": [
    "dist",
    "src",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "esbuild": ">=0.17.0"
  },
  "peerDependenciesMeta": {
    "esbuild": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5"
  }
}
